# =============================================================================
# Platform Configuration
# =============================================================================

# Environment
NODE_ENV=development

# =============================================================================
# Database Configuration (PostgreSQL / TimescaleDB)
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=charting_platform
POSTGRES_USER=charting_user
POSTGRES_PASSWORD=charting_dev_password
POSTGRES_URL=postgresql://charting_user:charting_dev_password@localhost:5432/charting_platform

# =============================================================================
# Valkey Configuration
# =============================================================================

VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379
VALKEY_PASSWORD=

# =============================================================================
# Go Platform API Configuration
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8080
API_LOG_LEVEL=info

# =============================================================================
# Rust Market Service Configuration
# =============================================================================

# Binance API (public endpoints - no auth required for market data)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com
BINANCE_FUTURES_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_REST_URL=https://fapi.binance.com

# Rust service settings
RUST_LOG_LEVEL=info
RUST_SERVICE_NAME=market-core

# =============================================================================
# Web Frontend Configuration
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Optional: External Services
# =============================================================================

# Future: Add external service API keys here
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=
